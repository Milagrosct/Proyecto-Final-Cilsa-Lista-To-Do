<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/Css/sidebar.css">
<link rel="stylesheet" href="/Css/categorias.css">
<link rel="stylesheet" href="/Css/modalEditarCategoria.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<title>Categorías</title>

</head>


<body>

<%- include("../partials/sidebar") %>
<!-- mensaje de exito -->
<% if (success) { %>

<div class="alert alert-success alert-dismissible fade show mensaje-exito">

    <%= success %>

    <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert">
    </button>

</div>

<% } %>


<main class="contenido">


<h1 class="text-center text-md-start"><i class="fa-solid fa-tags me-2"></i>Categorías</h1>

<p class="text-center text-md-start">
Organiza tus tareas con categorías personalizadas
</p>

<br>

<!-- Crear categoría -->

<form action="/categorias" method="POST">


<div class="form-categoria">

    <label>
        <i class="fa-solid fa-folder-plus"></i>
        Nombre de la categoría
    </label>

    <div class="input-categoria">

        <input 
            class="form-control"
            type="text"
            name="nombre"
            placeholder="Ej: Trabajo"
            minlength="3"
            maxlength="30"
            pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ0-9 ]+"
            required>

<div class="d-flex flex-column">
    <label class="mb-1">Color</label>

    <input
        type="color"
        name="color"
        class="form-control form-control-color input-color"
        value="#2563EB">
</div>

        <button class="btn btn-success boton-crear mt-3">
            <i class="fa-solid fa-plus"></i>
            Crear
        </button>

    </div>

</div>


</form>



<hr>


<h2>Lista de categorías</h2>

<% if (categorias.length === 0) { %>

<p>No hay categorías creadas.</p>

<% } else { %>

<div class="mt-4">

<% categorias.forEach(categoria => { %>

<div class="card mb-3">

    <div class="card-body d-flex justify-content-between align-items-center categoria">

<h5 class="mb-0">
    <span
        class="etiqueta-categoria"
        style="background-color:<%= categoria.color %>;">
        <%= categoria.nombre %>
    </span>
</h5>

        <div class="d-flex gap-2">

            <!-- Editar -->

            <button
                class="btn btn-primary btn-sm btn-editar"
                data-bs-toggle="modal"
                data-bs-target="#editarCategoria<%= categoria.id_categoria %>">

                    <i class="fa-regular fa-pen-to-square"></i> Editar

            </button>


            <!-- Eliminar -->

            <form
                action="/categorias/eliminar/<%= categoria.id_categoria %>"
                method="POST">

                <button
                    class="btn btn-danger btn-sm btn-eliminar"
                    onclick="return confirm('¿Eliminar esta categoría?')">

                  <i class="fa-solid fa-trash-can"></i> Eliminar

                </button>

            </form>

        </div>

    </div>

</div>


<!-- Modal -->

<%- include("modalEditar", { categoria }) %>


<% }) %>

</div>

<% } %>



</main>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


</body>

</html>