<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/Css/sidebar.css">
<link rel="stylesheet" href="/Css/categorias.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<title>Categorías</title>

</head>


<body>

<%- include("../partials/sidebar") %>


<main class="contenido">


<h1>Categorías</h1>

<p>
Organiza tus tareas con categorías personalizadas
</p>



<!-- Crear categoría -->

<form action="/categorias" method="POST">


<div class="form-categoria">

    <label>
        <i class="fa-solid fa-folder-plus"></i>
        Nombre de la categoría
    </label>

    <div class="input-categoria">

        <input 
            class="form-control"
            type="text"
            name="nombre"
            placeholder="Ej: Trabajo"
            required>

        <button class="btn btn-success boton-crear">
            <i class="fa-solid fa-plus"></i>
            Crear
        </button>

    </div>

</div>


</form>



<hr>


<h2>Lista de categorías</h2>

<% if (categorias.length === 0) { %>

<p>No hay categorías creadas.</p>

<% } else { %>

<div class="mt-4">

<% categorias.forEach(categoria => { %>

<div class="card mb-3">

    <div class="card-body d-flex justify-content-between align-items-center categoria">

        <h5 class="mb-0">

            <%= categoria.nombre %>

        </h5>

        <div class="d-flex gap-2">

            <!-- Editar -->

            <button
                class="btn btn-primary btn-sm btn-editar"
                data-bs-toggle="modal"
                data-bs-target="#editarCategoria<%= categoria.id_categoria %>">

                    <i class="fa-regular fa-pen-to-square"></i> Editar

            </button>


            <!-- Eliminar -->

            <form
                action="/categorias/eliminar/<%= categoria.id_categoria %>"
                method="POST">

                <button
                    class="btn btn-danger btn-sm btn-eliminar"
                    onclick="return confirm('¿Eliminar esta categoría?')">

                  <i class="fa-solid fa-trash-can"></i> Eliminar

                </button>

            </form>

        </div>

    </div>

</div>


<!-- Modal -->

<%- include("modalEditar", { categoria }) %>


<% }) %>

</div>

<% } %>



</main>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


</body>

</html>