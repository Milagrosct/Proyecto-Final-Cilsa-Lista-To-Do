<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tareas</title>
    <link  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/Css/sidebar.css">
    <link rel="stylesheet" href="/Css/tareas/tareas.css">
    <link rel="stylesheet" href="/Css/tareas/modalEditar.css">
    <!-- font awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    

</head>
<body>
    <!-- Barra de dashboard - sidebar (partials/sidebar.ejs)-->
<%- include("../partials/sidebar") %>
<div class="contenido-principal">
<!-- mensaje alerta exito -->
<% if (success) { %>
<div class="alert alert-success alert-dismissible fade show mt-3 mensaje-exito">

    <%= success %>

    <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert">
    </button>

</div>
<% } %>

<main class="contenido">  
<h1 class="text-center text-md-start">Hola <%= usuario.nombre %> 👋</h1>

<br>
<!-- Boton de Crear tareas  -->
 <div class="d-flex justify-content-center justify-content-md-start mb-4">
<button class="btn btn-success btn-crear" data-bs-toggle="modal" data-bs-target="#crearTarea">

    <i class="fa-solid fa-plus"></i>
    Nueva tarea
</button>
</div>
<!-- Modal de crear tareas -->
 <div class="modal fade" id="crearTarea" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title">Crear nueva tarea</h5>
<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<!-- form de crear tareas -->
<form action="/tareas" method="POST">

    <div class="modal-body">

    <label>Nombre</label>
    <input type="text"name="nombre"class="form-control" placeholder="Nombre de la tarea"  minlength="3"
    maxlength="100"
    pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ0-9 .,_-]+"
    title="Solo letras, números, espacios, punto, coma, guion y guion bajo" required>

    <label>Descripción</label>
    <textarea name="descripcion" class="form-control" maxlength="300"></textarea>

    <label>Categoría</label>

    <select name="id_categoria"class="form-control" required>
        <option value="">Seleccione categoría</option>
            <% categorias.forEach(categoria=>{ %>
        <option value="<%= categoria.id_categoria %>">
        <%= categoria.nombre %>
        </option>
<% }) %>
    </select>

<label>Prioridad</label>
<select name="prioridad"class="form-control">
    <option value="Baja">Baja</option>
    <option value="Media" selected>Media</option>
    <option value="Alta">Alta</option>
</select>

<!-- FECHAS -->
<label>Fecha inicio</label>
<input type="datetime-local"name="fecha_inicio" class="form-control">

<label>Fecha vencimiento</label>
<input type="datetime-local" name="fecha_vencimiento" class="form-control" min="<%= new Date().toISOString().slice(0,16) %>">

<hr>


</div>

<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
    <button type="submit" class="btn btn-success btn-creartarea">Crear tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Filtros -->
<form action="/tareas" method="GET" class="row g-3 justify-content-center align-items-center mb-4">

    <div class="col-12 col-md-4">
        <div class="busqueda">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input
                type="text"
                name="buscar"
                placeholder="Buscar tarea..."
                value="<%= filtros.buscar %>">
        </div>
    </div>
<!-- Filtro por categorias -->
    <div class="col-12 col-sm-6 col-md-2">
        <select name="categoria" class="form-select filtro-select">
            <option value="">Categoría</option>

            <% categorias.forEach(categoria=>{ %>

                <option
                    value="<%= categoria.id_categoria %>"
                    <%= filtros.categoria==categoria.id_categoria?"selected":"" %>>
                    <%= categoria.nombre %>
                </option>

            <% }) %>

        </select>
    </div>
    <!-- filtro por prioridad -->
    <div class="col-12 col-sm-6 col-md-2">
        <select name="prioridad" class="form-select filtro-select">
            <option value="">Prioridad</option>
            <option value="Baja" <%= filtros.prioridad=="Baja"?"selected":"" %>>Baja</option>
            <option value="Media" <%= filtros.prioridad=="Media"?"selected":"" %>>Media</option>
            <option value="Alta" <%= filtros.prioridad=="Alta"?"selected":"" %>>Alta</option>
        </select>
    </div>
    <!-- filtro por estado -->
    <div class="col-12 col-sm-6 col-md-2">
        <select name="estado" class="form-select filtro-select">
            <option value="">Estado</option>
            <option value="1" <%= filtros.estado=="1"?"selected":"" %>>Pendiente</option>
            <option value="2" <%= filtros.estado=="2"?"selected":"" %>>En progreso</option>
            <option value="3" <%= filtros.estado=="3"?"selected":"" %>>Completada</option>
            
        </select>
        
    </div>
    <!-- boton filtrar -->
    <div class="col-12 col-sm-6 col-md-2 d-grid">
        <button class="btn btn-primary btn-filtrar">
            <i class="fa-solid fa-filter"></i> Filtrar
        </button>
    </div>

</form>

<!-- Mostrar tareas -->
 <br>
<h2 class="text-center text-md-start"><i class="fa-solid fa-list-check me-2"></i> Mis tareas</h2>

<!-- tareas -->
<% if (tareas.length === 0) { %>

    <p>No tenés tareas todavía</p>

<% } else { %>

<div class="contenedor-tareas">

<% tareas.forEach(tarea => { %>

    <%- include("cardTarea", {
        tarea,
        usuario,
        categorias
    }) %>

<% }) %>

</div>

<% } %>
</div>
</main>  

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>