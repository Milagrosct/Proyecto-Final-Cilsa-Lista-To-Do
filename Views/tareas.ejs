<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tareas</title>
    <link rel="stylesheet" href="/Css/tareas.css">
    <link  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

    <h1>
        
Hola <%= usuario.nombre %> 👋
</h1>
<!-- Barra de dashboard - sidebar (partials/sidebar.ejs)-->
<%- include("partials/sidebar") %>


<!-- Boton de Crear tareas  -->
<button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#crearTarea">+ Crear tarea</button>
<!-- Modal de crear tareas -->
 <div class="modal fade" id="crearTarea" tabindex="-1">
<div class="modal-dialog">
<div class="modal-content">
<div class="modal-header">
<h5 class="modal-title">Crear nueva tarea</h5>
<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<!-- form de crear tareas -->
<form action="/tareas" method="POST">

    <div class="modal-body">

    <label>Nombre</label>
    <input type="text"name="nombre"class="form-control" placeholder="Nombre de la tarea" required>

    <label>Descripción</label>
    <textarea name="descripcion" class="form-control"></textarea>

    <label>Categoría</label>

    <select name="id_categoria"class="form-control" required>
        <option value="">Seleccione categoría</option>
            <% categorias.forEach(categoria=>{ %>
        <option value="<%= categoria.id_categoria %>">
        <%= categoria.nombre %>
        </option>
<% }) %>
    </select>

<label>Prioridad</label>
<select name="prioridad"class="form-control">
    <option value="Baja">Baja</option>
    <option value="Media" selected>Media</option>
    <option value="Alta">Alta</option>
</select>

<label>Fecha inicio</label>
<input type="datetime-local"name="fecha_inicio" class="form-control">

<label>Fecha vencimiento</label>
<input type="datetime-local" name="fecha_vencimiento" class="form-control">

<hr>


</div>

<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
    <button type="submit" class="btn btn-success">Crear tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Mostrar tareas -->
<h2>Mis tareas</h2>



<!-- Filtros -->
<form action="/tareas" method="GET" class="mb-4">


    <!-- Buscar tareas -->
    <input 
        type="text" 
        name="buscar" 
        placeholder="Buscar tarea..." 
        value="<%= filtros.buscar %>"
        class="form-control mb-2">


    <!-- Buscar categoria -->
    <select name="categoria" class="form-control mb-2">

        <option value="">
            Todas las categorías
        </option>

        <% categorias.forEach(categoria => { %>

            <option 
            value="<%= categoria.id_categoria %>"
            <%= filtros.categoria == categoria.id_categoria ? "selected" : "" %>>
                <%= categoria.nombre %>
            </option>

        <% }) %>

    </select>


    <!-- Buscar por prioridad -->
    <select name="prioridad" class="form-control mb-2">

        <option value="">
            Todas las prioridades
        </option>

        <option value="Baja"
        <%= filtros.prioridad=="Baja"?"selected":"" %>>
            Baja
        </option>

        <option value="Media"
        <%= filtros.prioridad=="Media"?"selected":"" %>>
            Media
        </option>

        <option value="Alta"
        <%= filtros.prioridad=="Alta"?"selected":"" %>>
            Alta
        </option>

    </select>


    <button type="submit" class="btn btn-primary">
        Buscar
    </button>


</form>

<!-- tareas -->
<% if (tareas.length === 0) { %>

    <p>No tenés tareas todavía</p>

<% } else { %>

<div class="contenedor-tareas">

<% tareas.forEach(tarea => { %>

    <%- include("partials/tareas/cardTarea", {
        tarea,
        usuario,
        categorias
    }) %>

<% }) %>

</div>

<% } %>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>